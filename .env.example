# ─────────────────────────────────────────────────────────────
# AI Video Agent — Environment Variables
# Copy this file to .env and fill in your API keys.
# ─────────────────────────────────────────────────────────────

# Groq API key (LLM agent backbone)
# Get yours → https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API key (multimodal video transcription)
# Get yours → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# SerpAPI key (YouTube video search)
# Get yours → https://serpapi.com/manage-api-key
SERPAPI_KEY=your_serpapi_key_here
